{
  "compilerOptions": {
    "target": "ES2022",
    "outDir": "dist",
    "rootDir": "Mytests",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "strict": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["node", "@playwright/test", "@cucumber/cucumber"]
  },
  "include": ["Mytests/**/*"]
}