{
  "default": {
    "require": ["Mytests/Steps/**/*.ts","Mytests/supports/**/*.ts"],
    "requireModule": ["ts-node/register"],
    "paths": ["Mytests/**/*.feature"],
    "parallel" : 1,
    "format": [
      "progress",
      "html:reports/cucumber-report.html"
    ],
    "formatOptions": { "snippetInterface": "async-await" }
  }
}